{
  "name": "read_file",
  "description": "Read and parse a file",
  "input_schema": {
    "type": "object",
    "properties": {
      "file_path": {
        "type": "string",
        "description": "Path to the file"
      },
      "format": {
        "type": "string",
        "enum": ["text", "json", "yaml", "csv"],
        "description": "Expected format"
      }
    },
    "required": ["file_path"]
  }
}
